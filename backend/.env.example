# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Local or MongoDB Atlas)
# Local default: mongodb://127.0.0.1:27017/socrates
# Atlas example: mongodb+srv://<username>:<password>@cluster.mongodb.net/socrates?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/socrates

# Authentication
JWT_SECRET=socrates_secret_jwt_key_2026_dev
JWT_EXPIRE=30d
